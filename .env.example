# Sécurité
SECRET_KEY=changeme-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données (Cloud SQL Proxy en local)
DB_NAME=paramynd_admin
DB_USER=admin
DB_PASSWORD=admin123
DB_HOST=127.0.0.1
DB_PORT=5433

# GCP
GCP_PROJECT_ID=yellow-455523
GCP_REGION=europe-west9
ARTIFACT_REGISTRY_REPO=paramynd
PARAMYND_IMAGE_NAME=app
CLOUD_SQL_INSTANCE=yellow-455523:europe-west9:yellow-db-paris

# Auth admin (emails autorisés à se connecter)
ALLOWED_ADMIN_EMAILS=admin@paramynd.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cloudflare DNS Automation
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# GitHub API (requis pour éviter le rate limit: 60 req/h sans token → 5000 req/h avec)
# Créer sur https://github.com/settings/tokens — scope: repo (lecture seule)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
